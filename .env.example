# ═══════════════════════════════════════════════════════════
# SGCI — Variables de Entorno
# Copiar a .env y completar valores reales
# NUNCA subir .env a control de versiones
# ═══════════════════════════════════════════════════════════

# ─── Entorno ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Base de Datos PostgreSQL ────────────────────────────────
DATABASE_URL=postgresql://sgci_user:sgci_dev_pass_2024@localhost:5432/sgci
POSTGRES_PASSWORD=sgci_dev_pass_2024

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://:redis_dev_pass_2024@localhost:6379
REDIS_PASSWORD=redis_dev_pass_2024

# ─── RabbitMQ ───────────────────────────────────────────────
RABBITMQ_URL=amqp://sgci_rabbit:rabbit_dev_pass_2024@localhost:5672/sgci
RABBITMQ_USER=sgci_rabbit
RABBITMQ_PASS=rabbit_dev_pass_2024

# ─── MinIO / S3 ─────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=sgci_minio
MINIO_SECRET_KEY=minio_dev_pass_2024
MINIO_ROOT_USER=sgci_minio
MINIO_ROOT_PASSWORD=minio_dev_pass_2024
MINIO_BUCKET=sgci-clinica

# ─── JWT (¡Cambiar en producción!) ──────────────────────────
# Generar con: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=CAMBIAR_EN_PRODUCCION_jwt_secret_minimo_64_caracteres_aleatorios_aqui
JWT_REFRESH_SECRET=CAMBIAR_EN_PRODUCCION_jwt_refresh_secret_diferente_del_access_token

# ─── Cifrado PHI — AES-256-GCM (¡Cambiar en producción!) ────
# Generar con: node -e "require('crypto').randomBytes(32).toString('hex')"
ENCRYPTION_KEY=CAMBIAR_EN_PRODUCCION_32_bytes_clave_aes256_para_phi_datos_personales

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_SHORT=20
RATE_LIMIT_MEDIUM=300
RATE_LIMIT_LONG=5000

# ─── Email — SendGrid ────────────────────────────────────────
# Obtener en: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
EMAIL_FROM=noreply@clinicasgci.mx
EMAIL_FROM_NAME=Clínica SGCI

# ─── SMS — AWS SNS ───────────────────────────────────────────
# Crear usuario IAM con permisos SNS en: https://console.aws.amazon.com/iam
AWS_SNS_ACCESS_KEY=
AWS_SNS_SECRET_KEY=
AWS_REGION=us-east-1

# ─── WhatsApp Business API (Meta) — STANDBY en MVP ──────────
# Obtener en: https://developers.facebook.com/apps/
# Proceso de tramitación: ver addendum v2.1 — semanas 1-10
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ─── Telemedicina — Daily.co ─────────────────────────────────
# Obtener en: https://dashboard.daily.co/developers
DAILY_API_KEY=
DAILY_RECORDING_BUCKET=

# ─── RENAPO — Validación CURP ────────────────────────────────
# Entorno de producción requiere convenio con RENAPO
RENAPO_URL=https://consultas.renapo.gob.mx

# ─── SAT — Validación RFC (LCO) ──────────────────────────────
SAT_LCO_URL=https://apisnet.col.gob.mx/wsSignature/SatWsSignature.svc

# ─── PAC — Timbrado CFDI 4.0 ─────────────────────────────────
# PAC certificado: Edicom, Diverza, Finkok, etc.
# Solicitar acceso sandbox para pruebas
PAC_URL=
PAC_USER=
PAC_PASS=

# ─── QuickBooks Online — STANDBY en MVP ─────────────────────
# Registrar app en: https://developer.intuit.com/app/developer/appdetail
# Proceso de activación: ver addendum v2.1 — sin fecha límite
QB_SYNC_ENABLED=false
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:3000/integrations/quickbooks/callback

# ─── Pagos — Conekta ─────────────────────────────────────────
# Obtener en: https://dashboard.conekta.com/settings/keys
CONEKTA_API_KEY=

# ─── Frontend URLs ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ─── Monitoreo (Grafana) ─────────────────────────────────────
GRAFANA_PASSWORD=grafana_dev_2024
