  stockDespues  Decimal    @db.Decimal(10, 3) @map("stock_despues")
  motivo        String?
  referencia    String?    // ID de consulta, orden de compra, etc.
  actorId       String?    @map("actor_id")
  createdAt     DateTime   @default(now()) @map("created_at")

