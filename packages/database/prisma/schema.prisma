// ─── FACTURACIÓN CFDI 4.0 ────────────────────────────────────

model Factura {
  id                    String        @id @default(uuid())
  pacienteId            String        @map("paciente_id")
  consultaId            String?       @unique @map("consulta_id")
  sedeId                String        @map("sede_id")
  numeroFacturaInterno  String        @unique @map("numero_factura_interno")
  cfdiUuid              String?       @unique @map("cfdi_uuid")
  cfdiXmlUrl            String?       @map("cfdi_xml_url")
  cfdiPdfUrl            String?       @map("cfdi_pdf_url")
  estadoCfdi            EstadoCFDI    @default(BORRADOR) @map("estado_cfdi")
  estadoPago            EstadoPago    @default(PENDIENTE) @map("estado_pago")
  rfcReceptor           String?       @map("rfc_receptor")
  razonSocialReceptor   String?       @map("razon_social_receptor")
  regimenFiscalReceptor String?       @map("regimen_fiscal_receptor")
  usoCfdi               String?       @map("uso_cfdi")
  subtotal              Decimal       @db.Decimal(12, 2)
  descuento             Decimal       @default(0.00) @db.Decimal(12, 2)
  iva                   Decimal       @default(0.00) @db.Decimal(12, 2)
  total                 Decimal       @db.Decimal(12, 2)
  moneda                String        @default("MXN")
  montoPagado           Decimal       @default(0.00) @db.Decimal(12, 2) @map("monto_pagado")
  saldo                 Decimal       @db.Decimal(12, 2) // total - montoPagado
  fechaTimbrado         DateTime?     @map("fecha_timbrado")
  qbSyncPending         Boolean       @default(true) @map("qb_sync_pending")
  qbInvoiceId           String?       @map("qb_invoice_id")
  qbPaymentId           String?       @map("qb_payment_id")
  qbSyncedAt            DateTime?     @map("qb_synced_at")
  actorId               String?       @map("actor_id")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  paciente              Paciente      @relation(fields: [pacienteId], references: [id])
  consulta              Consulta?     @relation(fields: [consultaId], references: [id])
  sede                  Sede          @relation(fields: [sedeId], references: [id])
  cargos                Cargo[]
  pagos                 Pago[]

  @@index([sedeId, createdAt])
  @@index([estadoCfdi])
  @@index([qbSyncPending])
  @@map("facturas")
}

model Cargo {
  id                String           @id @default(uuid())
  facturaId         String           @map("factura_id")
  servicioId        String?          @map("servicio_id")
  concepto          String
  claveSAT          String           @map("clave_sat")
  claveUnidadSAT    String           @map("clave_unidad_sat")
  precioUnitario    Decimal          @db.Decimal(10, 2) @map("precio_unitario")
  cantidad          Decimal          @default(1) @db.Decimal(8, 3)
  descuento         Decimal          @default(0.00) @db.Decimal(10, 2)
  subtotal          Decimal          @db.Decimal(10, 2)
  ivaAplicable      Boolean          @default(false) @map("iva_aplicable")
  tasaIva           Decimal          @default(0.00) @db.Decimal(5, 4) @map("tasa_iva")
  iva               Decimal          @default(0.00) @db.Decimal(10, 2)
  total             Decimal          @db.Decimal(10, 2)
  createdAt         DateTime         @default(now()) @map("created_at")

  factura           Factura          @relation(fields: [facturaId], references: [id])
  servicio          ServicioCatalogo? @relation(fields: [servicioId], references: [id])

  @@map("cargos")
}

model Pago {
  id              String          @id @default(uuid())
  facturaId       String          @map("factura_id")
  monto           Decimal         @db.Decimal(12, 2)
  metodoPago      MetodoPagoSAT   @map("metodo_pago")
  referencia      String?
  conektaChargeId String?         @map("conekta_charge_id")
  notas           String?
  actorId         String?         @map("actor_id")
  createdAt       DateTime        @default(now()) @map("created_at")

  factura         Factura         @relation(fields: [facturaId], references: [id])

  @@map("pagos")
}

model CortesCaja {
  id              String    @id @default(uuid())
  sedeId          String    @map("sede_id")
  usuarioId       String    @map("usuario_id")
  turno           String    // manana, tarde, noche
  fechaInicio     DateTime  @map("fecha_inicio")
  fechaFin        DateTime  @map("fecha_fin")
  totalEfectivo   Decimal   @db.Decimal(12, 2) @map("total_efectivo")
  totalTarjeta    Decimal   @db.Decimal(12, 2) @map("total_tarjeta")
  totalTransf     Decimal   @db.Decimal(12, 2) @map("total_transf")
  totalOtros      Decimal   @db.Decimal(12, 2) @map("total_otros")
  totalGeneral    Decimal   @db.Decimal(12, 2) @map("total_general")
  diferencia      Decimal   @default(0.00) @db.Decimal(12, 2)
  notas           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("cortes_caja")
}

